# 复制为 .env 并填入你自己的 key
DEEPSEEK_API_KEY=your_deepseek_api_key_here
BASE_URL=https://api.deepseek.com

# Neo4j 图数据库(通过 Docker 启动,见 README「快速开始」)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# LangSmith 可观测(可选,不配则跳过追踪;注意数据区要与注册时一致)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_service_key_here
LANGSMITH_PROJECT=moto-agent
# 美区默认无需此行;EU 用 https://eu.api.smith.langchain.com,APAC 用 https://apac.api.smith.langchain.com
LANGSMITH_ENDPOINT=https://apac.api.smith.langchain.com
